# =========================================================
# PetOS - Environment Variables Example
# =========================================================
# Este arquivo contém apenas EXEMPLOS.
# Nunca salve segredos reais no repositório.
# Copie para .env.local (desenvolvimento) ou configure no provedor.
# Política de segredos por ambiente:
# - manter valores diferentes para dev/staging/production
# - não reutilizar segredos entre ambientes
# - este arquivo é apenas contrato de chaves, sem valores reais
# =========================================================

# ---------------------------------------------------------
# Aplicação
# ---------------------------------------------------------
NODE_ENV=development
APP_NAME=PetOS
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------
# Banco de dados / Prisma
# ---------------------------------------------------------
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/petos"
# Opcional: URL direta para operações administrativas/migrations
DIRECT_DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/petos"

# ---------------------------------------------------------
# Autenticação (next-auth v4)
# Mantido compatível com dependência atual `next-auth` v4
# ---------------------------------------------------------
NEXTAUTH_SECRET=replace_with_a_long_random_secret
NEXTAUTH_URL=http://localhost:3000

# ---------------------------------------------------------
# Uploads / Storage (arquivos sensíveis fora do banco)
# ---------------------------------------------------------
UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

STORAGE_BUCKET=petos-files
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_BASE_URL=

# ---------------------------------------------------------
# Mercado Pago
# ---------------------------------------------------------
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_WEBHOOK_SECRET=

# ---------------------------------------------------------
# Stripe
# ---------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------
# E-mail transacional (MVP: comunicação manual + templates)
# ---------------------------------------------------------
EMAIL_PROVIDER=
EMAIL_FROM_NAME=PetOS
EMAIL_FROM_ADDRESS=no-reply@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# ---------------------------------------------------------
# IA / LLMs (MVP: apoio à geração de mensagens)
# ---------------------------------------------------------
OPENAI_API_KEY=
GEMINI_API_KEY=

# ---------------------------------------------------------
# Segurança e observabilidade
# ---------------------------------------------------------
LOG_LEVEL=info
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ---------------------------------------------------------
# Fallback técnico (regras por unidade prevalecem no domínio)
# ---------------------------------------------------------
DEFAULT_CANCELLATION_WINDOW_HOURS=24
DEFAULT_RESCHEDULE_WINDOW_HOURS=24
DEFAULT_NO_SHOW_TOLERANCE_MINUTES=15
DEFAULT_CURRENCY=BRL
DEFAULT_TIMEZONE=America/Sao_Paulo
