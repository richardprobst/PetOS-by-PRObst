# =========================================================
# PetOS - Environment Variables Example
# =========================================================
# Este arquivo contém apenas EXEMPLOS.
# Nunca salve segredos reais no repositório.
# Copie para .env.local (desenvolvimento) ou configure no provedor.
# =========================================================

# ---------------------------------------------------------
# Aplicação
# ---------------------------------------------------------
NODE_ENV=development
APP_NAME=PetOS
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PetOS

# ---------------------------------------------------------
# Banco de dados / Prisma
# ---------------------------------------------------------
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/petos"
DIRECT_DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/petos"

# ---------------------------------------------------------
# Autenticação (Auth.js / NextAuth.js)
# ---------------------------------------------------------
AUTH_SECRET=replace_with_a_long_random_secret
AUTH_URL=http://localhost:3000
TRUST_HOST=true

# ---------------------------------------------------------
# Sessão / Cookies
# ---------------------------------------------------------
SESSION_MAX_AGE=2592000
SESSION_UPDATE_AGE=86400
COOKIE_DOMAIN=localhost

# ---------------------------------------------------------
# Uploads / Storage
# Escolha a estratégia real do projeto.
# Para produção, prefira storage externo seguro.
# ---------------------------------------------------------
UPLOAD_DRIVER=s3
UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

STORAGE_BUCKET=petos-files
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_BASE_URL=

# ---------------------------------------------------------
# Mercado Pago
# ---------------------------------------------------------
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_WEBHOOK_URL=http://localhost:3000/api/webhooks/mercadopago

# ---------------------------------------------------------
# Stripe
# ---------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_URL=http://localhost:3000/api/webhooks/stripe

# ---------------------------------------------------------
# E-mail transacional
# Ex.: Resend, SendGrid, Postmark, SMTP etc.
# ---------------------------------------------------------
EMAIL_PROVIDER=resend
EMAIL_FROM_NAME=PetOS
EMAIL_FROM_ADDRESS=no-reply@example.com

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

RESEND_API_KEY=
SENDGRID_API_KEY=
POSTMARK_SERVER_TOKEN=

# ---------------------------------------------------------
# WhatsApp / Comunicação
# MVP: comunicação manual assistida.
# Deixe vazio se a integração automática ainda não existir.
# ---------------------------------------------------------
WHATSAPP_CLICK_TO_CHAT_BASE_URL=https://wa.me
WHATSAPP_DEFAULT_COUNTRY_CODE=55
WHATSAPP_DEFAULT_MESSAGE_PREFIX=

# ---------------------------------------------------------
# IA / LLMs
# MVP: geração assistida de mensagens e suporte interno.
# ---------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_FEATURES_ENABLED=true
AI_LOG_PROMPTS=false
AI_MAX_INPUT_CHARS=12000

# ---------------------------------------------------------
# Observabilidade / Logs
# ---------------------------------------------------------
LOG_LEVEL=info
ENABLE_AUDIT_LOGS=true
ENABLE_REQUEST_LOGS=true
SENTRY_DSN=

# ---------------------------------------------------------
# Rate limiting / Segurança
# ---------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
WEBHOOK_IP_ALLOWLIST=

# ---------------------------------------------------------
# Regras de negócio configuráveis por ambiente
# Valores finais devem respeitar ConfiguracoesUnidade no sistema.
# Estes valores servem como fallback técnico.
# ---------------------------------------------------------
DEFAULT_CANCELLATION_WINDOW_HOURS=24
DEFAULT_RESCHEDULE_WINDOW_HOURS=24
DEFAULT_NO_SHOW_TOLERANCE_MINUTES=15
DEFAULT_CURRENCY=BRL
DEFAULT_TIMEZONE=America/Sao_Paulo

# ---------------------------------------------------------
# Feature flags técnicas
# ---------------------------------------------------------
FEATURE_PAYMENTS_ENABLED=false
FEATURE_AI_ENABLED=true
FEATURE_EMAIL_ENABLED=false
FEATURE_STORAGE_ENABLED=true
FEATURE_AUDIT_ENABLED=true

# ---------------------------------------------------------
# Seed / Ambiente de desenvolvimento
# ---------------------------------------------------------
SEED_ADMIN_NAME=Administrador PetOS
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_me_before_use
SEED_DEFAULT_UNIT_NAME=Unidade Principal
