# =========================================================
# PetOS - Environment Variables Example
# =========================================================
# This file contains only development-safe example values.
# Copy it to .env.local for local development.
# For hosted staging, use `.env.staging.example` as the baseline instead.
# For the default local Docker setup, the MySQL credentials below
# match the service defined in docker-compose.yml.
# Replace secrets and integration credentials outside local development.
# =========================================================

# ---------------------------------------------------------
# Application
# ---------------------------------------------------------
NODE_ENV=development
APP_NAME=PetOS
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------
# Database / Prisma
# ---------------------------------------------------------
DATABASE_URL="mysql://petos:petos@127.0.0.1:3306/petos"
DIRECT_DATABASE_URL="mysql://petos:petos@127.0.0.1:3306/petos"

# ---------------------------------------------------------
# Authentication (next-auth v4)
# ---------------------------------------------------------
NEXTAUTH_SECRET=replace_with_a_long_random_secret_for_local_use
NEXTAUTH_URL=http://localhost:3000

# ---------------------------------------------------------
# Installer / updater bootstrap foundation
# Leave disabled unless you are intentionally opening the
# integrated installer preflight for a fresh environment.
# ---------------------------------------------------------
INSTALLER_ENABLED=false
INSTALLER_BOOTSTRAP_TOKEN=

# ---------------------------------------------------------
# Optional initial admin seed
# Leave blank if you do not want to create an admin automatically.
# ---------------------------------------------------------
ADMIN_SEED_NAME=Administrador PetOS
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=

# ---------------------------------------------------------
# Uploads / Storage
# ---------------------------------------------------------
UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,video/mp4

STORAGE_BUCKET=petos-files
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_BASE_URL=

# ---------------------------------------------------------
# Fiscal integration foundation (Phase 2 foundation only)
# Keep blank until a provider is explicitly enabled.
# ---------------------------------------------------------
FISCAL_PROVIDER=
FISCAL_API_BASE_URL=
FISCAL_API_TOKEN=

# ---------------------------------------------------------
# Mercado Pago
# ---------------------------------------------------------
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_WEBHOOK_SECRET=

# ---------------------------------------------------------
# Stripe
# ---------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------
# Transactional email
# MVP scope: manual communication plus templates
# ---------------------------------------------------------
EMAIL_PROVIDER=
EMAIL_FROM_NAME=PetOS
EMAIL_FROM_ADDRESS=no-reply@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# ---------------------------------------------------------
# AI / LLMs
# MVP scope: message generation support
# ---------------------------------------------------------
OPENAI_API_KEY=
GEMINI_API_KEY=

# ---------------------------------------------------------
# Security and observability
# ---------------------------------------------------------
LOG_LEVEL=info
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ---------------------------------------------------------
# Technical fallback
# Unit-level configuration should override these values
# ---------------------------------------------------------
DEFAULT_CANCELLATION_WINDOW_HOURS=24
DEFAULT_RESCHEDULE_WINDOW_HOURS=24
DEFAULT_NO_SHOW_TOLERANCE_MINUTES=15
DEFAULT_PRE_CHECK_IN_WINDOW_HOURS=48
DEFAULT_DEPOSIT_EXPIRATION_MINUTES=60
DEFAULT_CLIENT_CREDIT_EXPIRATION_DAYS=180
DEFAULT_DOCUMENT_RETENTION_DAYS=180
DEFAULT_DOCUMENT_SIGNED_URL_TTL_SECONDS=900
DEFAULT_CRM_INACTIVE_DAYS=90
DEFAULT_CRM_REVIEW_DELAY_HOURS=24
DEFAULT_CRM_POST_SERVICE_DELAY_HOURS=6
DEFAULT_INVENTORY_ALLOW_NEGATIVE_STOCK=false
DEFAULT_PRODUCT_MIN_STOCK_QUANTITY=1
DEFAULT_POS_AUTO_FISCAL_DOCUMENT=false
DEFAULT_TEAM_SHIFT_MINUTES=480
DEFAULT_TIME_CLOCK_TOLERANCE_MINUTES=10
DEFAULT_PAYROLL_PERIOD_DAYS=30
DEFAULT_INTEGRATION_EVENT_RETENTION_DAYS=90
DEFAULT_CURRENCY=BRL
DEFAULT_TIMEZONE=America/Sao_Paulo
