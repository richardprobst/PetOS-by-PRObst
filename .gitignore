# ------------------------------
# PetOS - .gitignore
# Stack: Next.js + TypeScript + Prisma + MySQL
# ------------------------------

# dependencies
/node_modules
/.pnp
.pnp.*

# package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# next.js
/.next/
/out/

# production builds
/build/
/dist/

# coverage / test artifacts
/coverage/
/.nyc_output/
/test-results/
/playwright-report/

# prisma
/prisma/dev.db
/prisma/dev.db-journal
/prisma/*.db
/prisma/*.db-journal

# env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# keep only example env tracked
!.env.example

# logs
logs
*.log

# runtime data
pids
*.pid
*.seed
*.pid.lock

# caches
.cache/
.turbo/
.eslintcache
.stylelintcache

# typescript
*.tsbuildinfo
next-env.d.ts

# editor / ide
.vscode/
.idea/
*.swp
*.swo
*.orig

# os files
.DS_Store
Thumbs.db
desktop.ini

# local upload/storage temp files
/uploads/
/storage/
/tmp/
/temp/

# secrets / certs
*.pem
*.key
*.crt
*.p12
*.pfx

# misc
.vercel/
