{
  "name": "petos",
  "version": "0.2.0",
  "private": true,
  "description": "PetOS — sistema SaaS para pet shops, banho e tosa, focado no mercado brasileiro.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0 <25",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.4.2",
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "node scripts/clean-path.mjs .next && next build",
    "start": "node scripts/start-standalone.mjs",
    "start:legacy": "next start",
    "start:standalone": "node scripts/start-standalone.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --import tsx --test --test-isolation=none tests/**/*.test.ts",
    "test:watch": "node --import tsx --test --test-isolation=none --watch tests/**/*.test.ts",
    "typecheck": "node -e \"require('node:fs').rmSync('.next/types',{ recursive: true, force: true })\" && next typegen && tsc --noEmit",
    "check:all": "npm run ops:preflight && npm run prisma:check && npm run typecheck && npm run lint && npm test && npm run build",
    "db:up": "docker compose up -d mysql",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mysql",
    "ops:preflight": "tsx scripts/operational-readiness.ts --mode=local --skip-db",
    "ops:check": "tsx scripts/operational-readiness.ts",
    "ops:preflight:staging": "tsx scripts/operational-readiness.ts --mode=staging --skip-db",
    "ops:check:staging": "tsx scripts/operational-readiness.ts --mode=staging",
    "ops:preflight:staging:file": "tsx scripts/operational-readiness.ts --mode=staging --env-file=.env.staging --skip-db",
    "ops:check:staging:file": "tsx scripts/operational-readiness.ts --mode=staging --env-file=.env.staging",
    "prisma:check": "npm run prisma:validate && npm run prisma:generate",
    "prisma:bootstrap": "npm run prisma:generate && npm run prisma:migrate:deploy && npm run prisma:seed",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio",
    "hostinger:bootstrap": "npm run prisma:migrate:deploy && npm run prisma:seed",
    "hostinger:smoke": "npm run ops:check:staging",
    "netlify:artifacts:sanitize": "node scripts/sanitize-netlify-artifacts.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.1",
    "@prisma/client": "6.15.0",
    "next": "^15.5.9",
    "next-auth": "4.24.11",
    "react": "^19.1.2",
    "react-dom": "^19.1.2",
    "react-hook-form": "7.62.0",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "@types/node": "24.3.1",
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9",
    "autoprefixer": "10.4.20",
    "eslint": "9.35.0",
    "eslint-config-next": "^15.5.9",
    "postcss": "8.4.49",
    "prisma": "6.15.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.20.5",
    "typescript": "5.9.2"
  }
}
