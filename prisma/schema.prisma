generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "mysql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum UserType {
  ADMIN
  CLIENT
  EMPLOYEE
}

enum AppointmentFinancialStatus {
  PENDING
  PARTIAL
  PAID
  INVOICED
  REFUNDED
  REVERSED
  EXEMPT
}

enum FinancialTransactionType {
  REVENUE
  EXPENSE
  ADJUSTMENT
  DEPOSIT
  REFUND
}

enum PaymentMethod {
  CASH
  PIX
  CARD
  BOLETO
  TRANSFER
  CLIENT_CREDIT
  OTHER
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  PARTIAL
  FAILED
  REFUNDED
  REVERSED
  VOIDED
}

enum MessageChannel {
  EMAIL
  WHATSAPP
}

enum MessageDeliveryStatus {
  DRAFT
  SENT
  FAILED
  CANCELED
}

enum CrmCampaignType {
  REVIEW_BOOSTER
  SEGMENTED_CAMPAIGN
  INACTIVE_RECOVERY
  PROFILE_OFFER
  POST_SERVICE_TRIGGER
}

enum CrmCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum CrmCampaignExecutionStatus {
  PREPARED
  COMPLETED
  FAILED
  CANCELED
}

enum CrmCampaignRecipientStatus {
  PREPARED
  LAUNCHED
  SKIPPED
  FAILED
  CANCELED
}

enum DocumentType {
  ANAMNESIS
  SERVICE_AUTHORIZATION
  TRANSPORT_AUTHORIZATION
  VACCINATION_RECORD
  OTHER
}

enum AssetAccessLevel {
  PRIVATE
  PROTECTED
  PUBLIC
}

enum SignatureMethod {
  DIGITAL_TYPED
  DIGITAL_DRAWN
  MANUAL
}

enum SignatureStatus {
  PENDING
  SIGNED
  REVOKED
  EXPIRED
}

enum MediaType {
  IMAGE
  VIDEO
  PDF
  OTHER
}

enum DepositStatus {
  PENDING
  CONFIRMED
  APPLIED
  FORFEITED
  REFUNDED
  CANCELED
  EXPIRED
}

enum DepositPurpose {
  SECURITY
  PREPAYMENT
}

enum RefundStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum CreditOriginType {
  REFUND
  DEPOSIT_CONVERSION
  MANUAL_ADJUSTMENT
  PROMOTION
  OTHER
}

enum IntegrationProvider {
  STRIPE
  MERCADO_PAGO
  FISCAL
  OTHER
}

enum IntegrationEventDirection {
  INBOUND
  OUTBOUND
}

enum IntegrationEventStatus {
  PENDING
  RECEIVED
  PROCESSED
  FAILED
  IGNORED
}

enum FiscalDocumentType {
  SERVICE_INVOICE
  CONSUMER_RECEIPT
}

enum FiscalDocumentStatus {
  PENDING
  ISSUED
  FAILED
  CANCELED
}

enum PetSizeCategory {
  SMALL
  MEDIUM
  LARGE
  GIANT
  UNKNOWN
}

enum ScheduleBlockType {
  UNAVAILABLE
  BREAK
  HOLIDAY
  TRANSPORT
  OTHER
}

enum WaitlistStatus {
  PENDING
  PROMOTED
  CANCELED
  EXPIRED
}

enum TaxiDogStatus {
  REQUESTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum InventoryMovementType {
  STOCK_IN
  SALE_OUT
  RETURN_IN
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
}

enum PosSaleStatus {
  OPEN
  COMPLETED
  CANCELED
}

enum EmployeePayrollMode {
  MONTHLY
  HOURLY
  COMMISSION_ONLY
}

enum TeamShiftType {
  WORK
  ON_CALL
  TRAINING
  DAY_OFF
}

enum TeamShiftStatus {
  PLANNED
  CONFIRMED
  CANCELED
}

enum TimeClockEntryStatus {
  OPEN
  CLOSED
  ADJUSTED
  VOIDED
}

enum PayrollRunStatus {
  DRAFT
  FINALIZED
  CANCELED
}

enum SystemLifecycleState {
  NOT_INSTALLED
  INSTALLING
  INSTALLED
  INSTALL_FAILED
  MAINTENANCE
  UPDATING
  UPDATE_FAILED
  REPAIR
}

enum RecoveryIncidentStatus {
  OPEN
  RESOLVED
}

enum UpdateExecutionMode {
  MANUAL
  RETRY
}

enum UpdateExecutionStatus {
  PREPARING
  RUNNING
  FAILED
  COMPLETED
}

enum UpdateRecoveryState {
  NONE
  RETRY_AVAILABLE
  MANUAL_INTERVENTION_REQUIRED
}

enum UpdateExecutionStepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

model Unit {
  id                       String                    @id @default(cuid()) @db.VarChar(191)
  name                     String                    @map("nome_unidade") @db.VarChar(191)
  address                  String?                   @map("endereco") @db.VarChar(255)
  phone                    String?                   @map("telefone") @db.VarChar(32)
  email                    String?                   @map("email") @db.VarChar(191)
  taxDocument              String?                   @map("cnpj") @db.VarChar(32)
  active                   Boolean                   @default(true) @map("ativo")
  createdAt                DateTime                  @default(now()) @map("data_criacao")
  updatedAt                DateTime                  @updatedAt @map("data_atualizacao")
  users                    User[]
  services                 Service[]
  employees                Employee[]
  appointments             Appointment[]
  financialTransactions    FinancialTransaction[]
  messageTemplates         MessageTemplate[]
  auditLogs                AuditLog[]
  settings                 UnitSetting[]
  documents                Document[]
  mediaAssets              MediaAsset[]
  deposits                 Deposit[]
  refunds                  Refund[]
  clientCredits            ClientCredit[]
  integrationEvents        IntegrationEvent[]
  fiscalDocuments          FiscalDocument[]
  appointmentCapacityRules AppointmentCapacityRule[]
  scheduleBlocks           ScheduleBlock[]
  waitlistEntries          WaitlistEntry[]
  taxiDogRides             TaxiDogRide[]
  crmCampaigns             CrmCampaign[]
  products                 Product[]
  inventoryStocks          InventoryStock[]
  inventoryMovements       InventoryMovement[]
  posSales                 PosSale[]
  teamShifts               TeamShift[]
  timeClockEntries         TimeClockEntry[]
  payrollRuns              PayrollRun[]

  @@map("Unidades")
}

model User {
  id                              String                          @id @default(cuid()) @db.VarChar(191)
  unitId                          String?                         @map("unidade_id") @db.VarChar(191)
  name                            String                          @map("nome") @db.VarChar(191)
  email                           String                          @unique(map: "Usuarios_email_key") @db.VarChar(191)
  passwordHash                    String?                         @map("senha_hash") @db.VarChar(255)
  phone                           String?                         @map("telefone") @db.VarChar(32)
  userType                        UserType                        @map("tipo_usuario")
  active                          Boolean                         @default(true) @map("ativo")
  createdAt                       DateTime                        @default(now()) @map("data_cadastro")
  updatedAt                       DateTime                        @updatedAt @map("data_atualizacao")
  unit                            Unit?                           @relation(fields: [unitId], references: [id])
  client                          Client?
  employee                        Employee?
  profiles                        UserProfile[]
  auditLogs                       AuditLog[]
  financialTransactions           FinancialTransaction[]          @relation("FinancialTransactionCreatedBy")
  messageLogs                     MessageLog[]                    @relation("SentByUser")
  statusChanges                   AppointmentStatusHistory[]      @relation("StatusChangedBy")
  reportCards                     ReportCard[]                    @relation("ReportCardCreatedBy")
  appointmentCheckIns             AppointmentCheckIn[]            @relation("AppointmentCheckInPerformedBy")
  uploadedDocuments               Document[]                      @relation("DocumentUploadedBy")
  signatureEntries                Signature[]                     @relation("SignatureSignerUser")
  uploadedMediaAssets             MediaAsset[]                    @relation("MediaAssetUploadedBy")
  archivedDocuments               Document[]                      @relation("DocumentArchivedBy")
  archivedMediaAssets             MediaAsset[]                    @relation("MediaAssetArchivedBy")
  createdDeposits                 Deposit[]                       @relation("DepositCreatedByUser")
  createdRefunds                  Refund[]                        @relation("RefundCreatedByUser")
  createdClientCredits            ClientCredit[]                  @relation("ClientCreditCreatedByUser")
  createdCreditUsages             CreditUsage[]                   @relation("CreditUsageCreatedByUser")
  integrationEvents               IntegrationEvent[]              @relation("IntegrationEventExecutedByUser")
  createdFiscalDocuments          FiscalDocument[]                @relation("FiscalDocumentCreatedByUser")
  createdAppointmentCapacityRules AppointmentCapacityRule[]       @relation("AppointmentCapacityRuleCreatedByUser")
  createdScheduleBlocks           ScheduleBlock[]                 @relation("ScheduleBlockCreatedByUser")
  createdWaitlistEntries          WaitlistEntry[]                 @relation("WaitlistEntryCreatedByUser")
  canceledWaitlistEntries         WaitlistEntry[]                 @relation("WaitlistEntryCanceledByUser")
  createdTaxiDogRides             TaxiDogRide[]                   @relation("TaxiDogRideCreatedByUser")
  submittedTutorPreCheckIns       TutorPreCheckIn[]               @relation("TutorPreCheckInSubmittedByUser")
  updatedCommunicationPreferences ClientCommunicationPreference[] @relation("ClientCommunicationPreferenceUpdatedByUser")
  createdCrmCampaigns             CrmCampaign[]                   @relation("CrmCampaignCreatedByUser")
  executedCrmCampaigns            CrmCampaignExecution[]          @relation("CrmCampaignExecutionExecutedByUser")
  createdInventoryMovements       InventoryMovement[]             @relation("InventoryMovementCreatedByUser")
  createdPosSales                 PosSale[]                       @relation("PosSaleCreatedByUser")
  createdTeamShifts               TeamShift[]                     @relation("TeamShiftCreatedByUser")
  openedTimeClockEntries          TimeClockEntry[]                @relation("TimeClockEntryOpenedByUser")
  closedTimeClockEntries          TimeClockEntry[]                @relation("TimeClockEntryClosedByUser")
  createdPayrollRuns              PayrollRun[]                    @relation("PayrollRunCreatedByUser")
  finalizedPayrollRuns            PayrollRun[]                    @relation("PayrollRunFinalizedByUser")
  openedRecoveryIncidents         RecoveryIncident[]              @relation("RecoveryIncidentOpenedByUser")
  resolvedRecoveryIncidents       RecoveryIncident[]              @relation("RecoveryIncidentResolvedByUser")
  startedUpdateExecutions         UpdateExecution[]               @relation("UpdateExecutionStartedByUser")
  completedUpdateExecutions       UpdateExecution[]               @relation("UpdateExecutionCompletedByUser")

  @@index([unitId], map: "Usuarios_unidade_id_idx")
  @@map("Usuarios")
}

model Client {
  userId                  String                         @id @map("id") @db.VarChar(191)
  address                 String?                        @map("endereco") @db.VarChar(255)
  city                    String?                        @map("cidade") @db.VarChar(120)
  state                   String?                        @map("estado") @db.VarChar(64)
  zipCode                 String?                        @map("cep") @db.VarChar(16)
  contactPreference       String?                        @map("preferencias_contato") @db.VarChar(191)
  generalNotes            String?                        @map("observacoes_gerais") @db.Text
  user                    User                           @relation(fields: [userId], references: [id])
  pets                    Pet[]
  appointments            Appointment[]
  messageLogs             MessageLog[]
  documents               Document[]
  mediaAssets             MediaAsset[]
  deposits                Deposit[]
  refunds                 Refund[]
  clientCredits           ClientCredit[]
  waitlistEntries         WaitlistEntry[]
  communicationPreference ClientCommunicationPreference?
  crmCampaignRecipients   CrmCampaignRecipient[]
  posSales                PosSale[]

  @@map("Clientes")
}

model Pet {
  id              String          @id @default(cuid()) @db.VarChar(191)
  clientId        String          @map("cliente_id") @db.VarChar(191)
  name            String          @map("nome") @db.VarChar(191)
  species         String          @map("especie") @db.VarChar(120)
  breed           String?         @map("raca") @db.VarChar(120)
  birthDate       DateTime?       @map("data_nascimento") @db.Date
  weightKg        Decimal?        @map("peso") @db.Decimal(8, 2)
  healthNotes     String?         @map("observacoes_saude") @db.Text
  allergies       String?         @map("alergias") @db.Text
  primaryPhotoUrl String?         @map("foto_url_principal") @db.VarChar(512)
  createdAt       DateTime        @default(now()) @map("data_criacao")
  updatedAt       DateTime        @updatedAt @map("data_atualizacao")
  client          Client          @relation(fields: [clientId], references: [userId])
  appointments    Appointment[]
  documents       Document[]
  mediaAssets     MediaAsset[]
  waitlistEntries WaitlistEntry[]

  @@index([clientId], map: "Pets_cliente_id_idx")
  @@map("Pets")
}

model Service {
  id                       String               @id @default(cuid()) @db.VarChar(191)
  unitId                   String?              @map("unidade_id") @db.VarChar(191)
  name                     String               @map("nome") @db.VarChar(191)
  description              String?              @map("descricao") @db.Text
  basePrice                Decimal              @map("preco_base") @db.Decimal(10, 2)
  estimatedDurationMinutes Int                  @map("duracao_estimada_minutos")
  active                   Boolean              @default(true) @map("ativo")
  createdAt                DateTime             @default(now()) @map("data_criacao")
  updatedAt                DateTime             @updatedAt @map("data_atualizacao")
  unit                     Unit?                @relation(fields: [unitId], references: [id])
  appointmentServices      AppointmentService[]
  waitlistEntries          WaitlistEntry[]

  @@index([unitId], map: "Servicos_unidade_id_idx")
  @@map("Servicos")
}

model Product {
  id                   String              @id @default(cuid()) @db.VarChar(191)
  unitId               String              @map("unidade_id") @db.VarChar(191)
  name                 String              @map("nome") @db.VarChar(191)
  sku                  String?             @map("sku") @db.VarChar(64)
  barcode              String?             @map("codigo_barras") @db.VarChar(64)
  description          String?             @map("descricao") @db.Text
  unitOfMeasure        String              @default("UN") @map("unidade_medida") @db.VarChar(32)
  salePrice            Decimal             @map("preco_venda") @db.Decimal(10, 2)
  costPrice            Decimal?            @map("preco_custo") @db.Decimal(10, 2)
  minimumStockQuantity Decimal             @default(0) @map("estoque_minimo") @db.Decimal(10, 3)
  trackInventory       Boolean             @default(true) @map("controla_estoque")
  active               Boolean             @default(true) @map("ativo")
  createdAt            DateTime            @default(now()) @map("data_criacao")
  updatedAt            DateTime            @updatedAt @map("data_atualizacao")
  unit                 Unit                @relation(fields: [unitId], references: [id])
  inventoryStocks      InventoryStock[]
  inventoryMovements   InventoryMovement[]
  saleItems            PosSaleItem[]

  @@unique([unitId, sku], map: "Produtos_unidade_id_sku_key")
  @@unique([unitId, barcode], map: "Produtos_unidade_id_codigo_barras_key")
  @@index([unitId, active], map: "Produtos_unidade_id_ativo_idx")
  @@map("Produtos")
}

model InventoryStock {
  id             String    @id @default(cuid()) @db.VarChar(191)
  unitId         String    @map("unidade_id") @db.VarChar(191)
  productId      String    @map("produto_id") @db.VarChar(191)
  quantityOnHand Decimal   @default(0) @map("quantidade_atual") @db.Decimal(10, 3)
  lastMovementAt DateTime? @map("data_ultimo_movimento")
  createdAt      DateTime  @default(now()) @map("data_criacao")
  updatedAt      DateTime  @updatedAt @map("data_atualizacao")
  unit           Unit      @relation(fields: [unitId], references: [id])
  product        Product   @relation(fields: [productId], references: [id])

  @@unique([unitId, productId], map: "EstoquesProduto_unidade_id_produto_id_key")
  @@index([productId], map: "EstoquesProduto_produto_id_idx")
  @@index([unitId, quantityOnHand], map: "EstoquesProduto_unidade_id_quantidade_atual_idx")
  @@map("EstoquesProduto")
}

model InventoryMovement {
  id              String                @id @default(cuid()) @db.VarChar(191)
  unitId          String                @map("unidade_id") @db.VarChar(191)
  productId       String                @map("produto_id") @db.VarChar(191)
  posSaleId       String?               @map("venda_pdv_id") @db.VarChar(191)
  posSaleItemId   String?               @map("item_venda_pdv_id") @db.VarChar(191)
  createdByUserId String?               @map("usuario_criacao_id") @db.VarChar(191)
  movementType    InventoryMovementType @map("tipo_movimento")
  quantity        Decimal               @map("quantidade") @db.Decimal(10, 3)
  quantityBefore  Decimal               @map("quantidade_anterior") @db.Decimal(10, 3)
  quantityAfter   Decimal               @map("quantidade_posterior") @db.Decimal(10, 3)
  reason          String?               @map("motivo") @db.VarChar(191)
  notes           String?               @map("observacoes") @db.Text
  occurredAt      DateTime              @default(now()) @map("data_movimento")
  createdAt       DateTime              @default(now()) @map("data_criacao")
  unit            Unit                  @relation(fields: [unitId], references: [id])
  product         Product               @relation(fields: [productId], references: [id])
  posSale         PosSale?              @relation(fields: [posSaleId], references: [id])
  posSaleItem     PosSaleItem?          @relation(fields: [posSaleItemId], references: [id])
  createdBy       User?                 @relation("InventoryMovementCreatedByUser", fields: [createdByUserId], references: [id])

  @@index([unitId, occurredAt], map: "MovimentacoesEstoque_unidade_id_data_movimento_idx")
  @@index([productId, occurredAt], map: "MovimentacoesEstoque_produto_id_data_movimento_idx")
  @@index([posSaleId], map: "MovimentacoesEstoque_venda_pdv_id_idx")
  @@index([posSaleItemId], map: "MovimentacoesEstoque_item_venda_pdv_id_idx")
  @@index([createdByUserId], map: "MovimentacoesEstoque_usuario_criacao_id_idx")
  @@map("MovimentacoesEstoque")
}

model PosSale {
  id                    String                 @id @default(cuid()) @db.VarChar(191)
  unitId                String                 @map("unidade_id") @db.VarChar(191)
  clientId              String?                @map("cliente_id") @db.VarChar(191)
  createdByUserId       String?                @map("usuario_criacao_id") @db.VarChar(191)
  status                PosSaleStatus          @default(OPEN) @map("status")
  notes                 String?                @map("observacoes") @db.Text
  subtotalAmount        Decimal                @default(0) @map("subtotal") @db.Decimal(10, 2)
  discountAmount        Decimal                @default(0) @map("desconto_total") @db.Decimal(10, 2)
  totalAmount           Decimal                @default(0) @map("total") @db.Decimal(10, 2)
  completedAt           DateTime?              @map("data_conclusao")
  canceledAt            DateTime?              @map("data_cancelamento")
  cancellationReason    String?                @map("motivo_cancelamento") @db.Text
  createdAt             DateTime               @default(now()) @map("data_criacao")
  updatedAt             DateTime               @updatedAt @map("data_atualizacao")
  unit                  Unit                   @relation(fields: [unitId], references: [id])
  client                Client?                @relation(fields: [clientId], references: [userId])
  createdBy             User?                  @relation("PosSaleCreatedByUser", fields: [createdByUserId], references: [id])
  items                 PosSaleItem[]
  financialTransactions FinancialTransaction[]
  inventoryMovements    InventoryMovement[]

  @@index([unitId, status, createdAt], map: "VendasPDV_unidade_id_status_data_criacao_idx")
  @@index([clientId], map: "VendasPDV_cliente_id_idx")
  @@index([createdByUserId], map: "VendasPDV_usuario_criacao_id_idx")
  @@map("VendasPDV")
}

model PosSaleItem {
  id                  String              @id @default(cuid()) @db.VarChar(191)
  saleId              String              @map("venda_pdv_id") @db.VarChar(191)
  productId           String              @map("produto_id") @db.VarChar(191)
  quantity            Decimal             @map("quantidade") @db.Decimal(10, 3)
  unitPrice           Decimal             @map("preco_unitario") @db.Decimal(10, 2)
  discountAmount      Decimal             @default(0) @map("desconto") @db.Decimal(10, 2)
  totalAmount         Decimal             @map("total") @db.Decimal(10, 2)
  productNameSnapshot String              @map("nome_produto_snapshot") @db.VarChar(191)
  skuSnapshot         String?             @map("sku_snapshot") @db.VarChar(64)
  createdAt           DateTime            @default(now()) @map("data_criacao")
  updatedAt           DateTime            @updatedAt @map("data_atualizacao")
  sale                PosSale             @relation(fields: [saleId], references: [id])
  product             Product             @relation(fields: [productId], references: [id])
  inventoryMovements  InventoryMovement[]

  @@index([saleId], map: "ItensVendaPDV_venda_pdv_id_idx")
  @@index([productId], map: "ItensVendaPDV_produto_id_idx")
  @@map("ItensVendaPDV")
}

model Employee {
  userId                   String                    @id @map("id") @db.VarChar(191)
  unitId                   String                    @map("unidade_id") @db.VarChar(191)
  role                     String                    @map("cargo") @db.VarChar(120)
  specialty                String?                   @map("especialidade") @db.VarChar(191)
  commissionPercentage     Decimal?                  @map("comissao_percentual") @db.Decimal(5, 2)
  payrollMode              EmployeePayrollMode       @default(MONTHLY) @map("modo_folha")
  baseCompensationAmount   Decimal?                  @map("valor_base_folha") @db.Decimal(10, 2)
  defaultDailyWorkMinutes  Int                       @default(480) @map("jornada_padrao_minutos")
  createdAt                DateTime                  @default(now()) @map("data_criacao")
  updatedAt                DateTime                  @updatedAt @map("data_atualizacao")
  user                     User                      @relation(fields: [userId], references: [id])
  unit                     Unit                      @relation(fields: [unitId], references: [id])
  appointmentServices      AppointmentService[]
  capacityRules            AppointmentCapacityRule[]
  scheduleBlocks           ScheduleBlock[]
  preferredWaitlistEntries WaitlistEntry[]           @relation("WaitlistPreferredEmployee")
  assignedTaxiDogRides     TaxiDogRide[]             @relation("TaxiDogRideAssignedDriver")
  teamShifts               TeamShift[]
  timeClockEntries         TimeClockEntry[]
  payrollRunEntries        PayrollRunEntry[]

  @@index([unitId], map: "Funcionarios_unidade_id_idx")
  @@map("Funcionarios")
}

model TeamShift {
  id               String           @id @default(cuid()) @db.VarChar(191)
  unitId           String           @map("unidade_id") @db.VarChar(191)
  employeeUserId   String           @map("funcionario_id") @db.VarChar(191)
  createdByUserId  String?          @map("usuario_criacao_id") @db.VarChar(191)
  shiftType        TeamShiftType    @default(WORK) @map("tipo_escala")
  status           TeamShiftStatus  @default(PLANNED) @map("status")
  startAt          DateTime         @map("data_hora_inicio")
  endAt            DateTime         @map("data_hora_fim")
  notes            String?          @map("observacoes") @db.Text
  createdAt        DateTime         @default(now()) @map("data_criacao")
  updatedAt        DateTime         @updatedAt @map("data_atualizacao")
  unit             Unit             @relation(fields: [unitId], references: [id])
  employee         Employee         @relation(fields: [employeeUserId], references: [userId])
  createdBy        User?            @relation("TeamShiftCreatedByUser", fields: [createdByUserId], references: [id])
  timeClockEntries TimeClockEntry[]

  @@index([unitId, status, startAt], map: "EscalasEquipe_unidade_id_status_data_hora_inicio_idx")
  @@index([employeeUserId, status, startAt], map: "EscalasEquipe_funcionario_id_status_data_hora_inicio_idx")
  @@index([createdByUserId], map: "EscalasEquipe_usuario_criacao_id_idx")
  @@map("EscalasEquipe")
}

model TimeClockEntry {
  id             String               @id @default(cuid()) @db.VarChar(191)
  unitId         String               @map("unidade_id") @db.VarChar(191)
  employeeUserId String               @map("funcionario_id") @db.VarChar(191)
  shiftId        String?              @map("escala_id") @db.VarChar(191)
  openedByUserId String?              @map("usuario_abertura_id") @db.VarChar(191)
  closedByUserId String?              @map("usuario_fechamento_id") @db.VarChar(191)
  status         TimeClockEntryStatus @default(OPEN) @map("status")
  clockInAt      DateTime             @map("data_hora_entrada")
  clockOutAt     DateTime?            @map("data_hora_saida")
  breakMinutes   Int                  @default(0) @map("minutos_intervalo")
  notes          String?              @map("observacoes") @db.Text
  createdAt      DateTime             @default(now()) @map("data_criacao")
  updatedAt      DateTime             @updatedAt @map("data_atualizacao")
  unit           Unit                 @relation(fields: [unitId], references: [id])
  employee       Employee             @relation(fields: [employeeUserId], references: [userId])
  shift          TeamShift?           @relation(fields: [shiftId], references: [id])
  openedBy       User?                @relation("TimeClockEntryOpenedByUser", fields: [openedByUserId], references: [id])
  closedBy       User?                @relation("TimeClockEntryClosedByUser", fields: [closedByUserId], references: [id])

  @@index([unitId, status, clockInAt], map: "RegistrosPonto_unidade_id_status_data_hora_entrada_idx")
