  profileId    String        @map("perfil_id") @db.VarChar(191)
  permissionId String        @map("permissao_id") @db.VarChar(191)
  createdAt    DateTime      @default(now()) @map("data_criacao")
  profile      AccessProfile @relation(fields: [profileId], references: [id])
  permission   Permission    @relation(fields: [permissionId], references: [id])

  @@id([profileId, permissionId])
  @@index([permissionId], map: "PerfilPermissao_permissao_id_idx")
  @@map("PerfilPermissao")
}

model UserProfile {
  userId    String        @map("usuario_id") @db.VarChar(191)
  profileId String        @map("perfil_id") @db.VarChar(191)
  createdAt DateTime      @default(now()) @map("data_criacao")
  user      User          @relation(fields: [userId], references: [id])
  profile   AccessProfile @relation(fields: [profileId], references: [id])

  @@id([userId, profileId])
  @@index([profileId], map: "UsuarioPerfil_perfil_id_idx")
  @@map("UsuarioPerfil")
}

model AuditLog {
  id         String   @id @default(cuid()) @db.VarChar(191)
  unitId     String?  @map("unidade_id") @db.VarChar(191)
  userId     String?  @map("usuario_id") @db.VarChar(191)
  action     String   @map("acao") @db.VarChar(191)
  entityName String   @map("entidade_afetada") @db.VarChar(191)
  entityId   String?  @map("entidade_id") @db.VarChar(191)
  occurredAt DateTime @default(now()) @map("data_hora")
  details    Json?    @map("detalhes_json")
  unit       Unit?    @relation(fields: [unitId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([unitId], map: "LogsAuditoria_unidade_id_idx")
  @@index([userId, occurredAt], map: "LogsAuditoria_usuario_id_data_hora_idx")
  @@index([entityName, entityId], map: "LogsAuditoria_entidade_afetada_entidade_id_idx")
  @@map("LogsAuditoria")
}

model UnitSetting {
  id          String   @id @default(cuid()) @db.VarChar(191)
  unitId      String   @map("unidade_id") @db.VarChar(191)
  key         String   @map("chave") @db.VarChar(120)
  value       String   @map("valor") @db.VarChar(255)
  description String?  @map("descricao") @db.Text
  createdAt   DateTime @default(now()) @map("data_criacao")
  updatedAt   DateTime @updatedAt @map("data_atualizacao")
  unit        Unit     @relation(fields: [unitId], references: [id])

  @@unique([unitId, key], map: "ConfiguracoesUnidade_unidade_id_chave_key")
  @@index([unitId], map: "ConfiguracoesUnidade_unidade_id_idx")
  @@map("ConfiguracoesUnidade")
}

model SystemRuntimeState {
  id                      String               @id @default("default") @map("chave_runtime") @db.VarChar(64)
  lifecycleState          SystemLifecycleState @default(NOT_INSTALLED) @map("estado_ciclo_vida")
  installerLockedAt       DateTime?            @map("instalador_bloqueado_em")
  installationCompletedAt DateTime?            @map("instalacao_concluida_em")
  maintenanceReason       String?              @map("motivo_manutencao") @db.VarChar(255)
  maintenanceActivatedAt  DateTime?            @map("manutencao_ativada_em")
  currentVersion          String?              @map("versao_atual") @db.VarChar(64)
  previousVersion         String?              @map("versao_anterior") @db.VarChar(64)
  manifestHash            String?              @map("manifest_hash") @db.VarChar(191)
  updatedByUserId         String?              @map("atualizado_por_usuario_id") @db.VarChar(191)
  lastTransitionAt        DateTime             @default(now()) @map("data_ultima_transicao")
  createdAt               DateTime             @default(now()) @map("data_criacao")
  updatedAt               DateTime             @updatedAt @map("data_atualizacao")

  @@map("EstadoRuntimeSistema")
}

model RecoveryIncident {
  id               String                 @id @default(cuid()) @db.VarChar(191)
  openedByUserId   String?                @map("aberto_por_usuario_id") @db.VarChar(191)
  resolvedByUserId String?                @map("resolvido_por_usuario_id") @db.VarChar(191)
  lifecycleState   SystemLifecycleState   @map("estado_ciclo_vida")
  status           RecoveryIncidentStatus @default(OPEN) @map("status_incidente")
  title            String                 @map("titulo") @db.VarChar(191)
  summary          String                 @map("resumo") @db.Text
  details          Json?                  @map("detalhes_json")
  openedAt         DateTime               @default(now()) @map("aberto_em")
  resolvedAt       DateTime?              @map("resolvido_em")
  createdAt        DateTime               @default(now()) @map("data_criacao")
  updatedAt        DateTime               @updatedAt @map("data_atualizacao")
  openedByUser     User?                  @relation("RecoveryIncidentOpenedByUser", fields: [openedByUserId], references: [id])
  resolvedByUser   User?                  @relation("RecoveryIncidentResolvedByUser", fields: [resolvedByUserId], references: [id])

  @@index([status, openedAt], map: "IncidentesRecovery_status_aberto_em_idx")
  @@index([openedByUserId], map: "IncidentesRecovery_aberto_por_usuario_id_idx")
  @@index([resolvedByUserId], map: "IncidentesRecovery_resolvido_por_usuario_id_idx")
  @@map("IncidentesRecovery")
}

model UpdateExecution {
  id                     String                 @id @default(cuid()) @db.VarChar(191)
  startedByUserId        String?                @map("iniciado_por_usuario_id") @db.VarChar(191)
  completedByUserId      String?                @map("concluido_por_usuario_id") @db.VarChar(191)
  retriedFromExecutionId String?                @map("retentativa_da_execucao_id") @db.VarChar(191)
  mode                   UpdateExecutionMode    @default(MANUAL) @map("modo_execucao")
  status                 UpdateExecutionStatus  @default(PREPARING) @map("status_execucao")
  recoveryState          UpdateRecoveryState    @default(NONE) @map("estado_recovery")
  sourceVersion          String                 @map("versao_origem") @db.VarChar(64)
  targetVersion          String                 @map("versao_alvo") @db.VarChar(64)
  manifestHash           String                 @map("manifest_hash") @db.VarChar(191)
  seedPolicy             String                 @map("seed_policy") @db.VarChar(64)
  requiresMaintenance    Boolean                @default(false) @map("exige_manutencao")
  requiresBackup         Boolean                @default(false) @map("exige_backup")
  lastSuccessfulStepCode String?                @map("ultimo_passo_sucesso") @db.VarChar(64)
  lastFailedStepCode     String?                @map("ultimo_passo_falha") @db.VarChar(64)
  failureSummary         String?                @map("resumo_falha") @db.Text
  preflightSnapshot      Json?                  @map("preflight_json")
  lockExpiresAt          DateTime               @map("lock_expira_em")
  startedAt              DateTime               @default(now()) @map("iniciado_em")
  completedAt            DateTime?              @map("concluido_em")
  failedAt               DateTime?              @map("falhou_em")
  maintenanceEnteredAt   DateTime?              @map("manutencao_ativada_em")
  maintenanceExitedAt    DateTime?              @map("manutencao_desativada_em")
  retryCount             Int                    @default(0) @map("quantidade_retentativas")
  createdAt              DateTime               @default(now()) @map("data_criacao")
  updatedAt              DateTime               @updatedAt @map("data_atualizacao")
  startedByUser          User?                  @relation("UpdateExecutionStartedByUser", fields: [startedByUserId], references: [id])
  completedByUser        User?                  @relation("UpdateExecutionCompletedByUser", fields: [completedByUserId], references: [id])
  retriedFromExecution   UpdateExecution?       @relation("UpdateExecutionRetryChain", fields: [retriedFromExecutionId], references: [id])
  retryExecutions        UpdateExecution[]      @relation("UpdateExecutionRetryChain")
  steps                  UpdateExecutionStep[]

  @@index([status, lockExpiresAt], map: "ExecucoesUpdate_status_execucao_lock_expira_em_idx")
  @@index([startedByUserId], map: "ExecucoesUpdate_iniciado_por_usuario_id_idx")
  @@index([completedByUserId], map: "ExecucoesUpdate_concluido_por_usuario_id_idx")
  @@index([retriedFromExecutionId], map: "ExecucoesUpdate_retentativa_da_execucao_id_idx")
  @@index([startedAt], map: "ExecucoesUpdate_iniciado_em_idx")
  @@map("ExecucoesUpdate")
}

model UpdateExecutionStep {
  id            String                    @id @default(cuid()) @db.VarChar(191)
  executionId   String                    @map("execucao_update_id") @db.VarChar(191)
  code          String                    @map("codigo_passo") @db.VarChar(64)
  label         String                    @map("titulo_passo") @db.VarChar(191)
  position      Int                       @map("ordem_passo")
  status        UpdateExecutionStepStatus @default(PENDING) @map("status_passo")
  payload       Json?                     @map("payload_json")
  errorSummary  String?                   @map("resumo_erro") @db.Text
  startedAt     DateTime?                 @map("iniciado_em")
  completedAt   DateTime?                 @map("concluido_em")
  failedAt      DateTime?                 @map("falhou_em")
  durationMs    Int?                      @map("duracao_ms")
  createdAt     DateTime                  @default(now()) @map("data_criacao")
  updatedAt     DateTime                  @updatedAt @map("data_atualizacao")
  execution     UpdateExecution           @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@unique([executionId, code], map: "PassosExecucaoUpdate_execucao_update_id_codigo_passo_key")
  @@index([executionId, position], map: "PassosExecucaoUpdate_execucao_update_id_ordem_passo_idx")
  @@index([status], map: "PassosExecucaoUpdate_status_passo_idx")
  @@map("PassosExecucaoUpdate")
}
