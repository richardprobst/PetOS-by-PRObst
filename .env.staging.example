# =========================================================
# PetOS - Staging Environment Variables Example
# =========================================================
# Copy this file to .env.staging only when rehearsing staging
# locally with file-based configuration.
# In a hosted environment, inject the same variables directly
# in the provider instead of committing or depending on this file.
# Replace every placeholder before booting the application.
# =========================================================

# ---------------------------------------------------------
# Application
# ---------------------------------------------------------
NODE_ENV=production
APP_NAME=PetOS
APP_URL=https://staging.petos.example.com
NEXT_PUBLIC_APP_URL=https://staging.petos.example.com

# ---------------------------------------------------------
# Database / Prisma
# Use the hosted MySQL instance for staging.
# Do not keep localhost values here.
# ---------------------------------------------------------
DATABASE_URL="mysql://petos:replace_with_strong_password@mysql-staging.example.internal:3306/petos_staging"
DIRECT_DATABASE_URL="mysql://petos:replace_with_strong_password@mysql-staging.example.internal:3306/petos_staging"

# ---------------------------------------------------------
# Authentication (next-auth v4)
# NEXTAUTH_SECRET must be random and at least 32 chars.
# ---------------------------------------------------------
NEXTAUTH_SECRET=replace_with_a_long_random_secret_for_staging_use
NEXTAUTH_URL=https://staging.petos.example.com

# ---------------------------------------------------------
# Installer / updater bootstrap foundation
# Keep disabled after the environment is installed. If you
# deliberately enable it for a fresh setup, configure a
# strong bootstrap token and rotate it after use.
# ---------------------------------------------------------
INSTALLER_ENABLED=false
INSTALLER_BOOTSTRAP_TOKEN=

# ---------------------------------------------------------
# Optional initial admin seed
# Leave blank if you do not want to create an admin automatically.
# ---------------------------------------------------------
ADMIN_SEED_NAME=Administrador PetOS
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=

# ---------------------------------------------------------
# Uploads / Storage
# ---------------------------------------------------------
UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,video/mp4

STORAGE_BUCKET=petos-files-staging
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_BASE_URL=

# ---------------------------------------------------------
# Fiscal integration foundation (Phase 2 foundation only)
# Configure all three values together only when fiscal
# integration is explicitly enabled in staging.
# ---------------------------------------------------------
FISCAL_PROVIDER=
FISCAL_API_BASE_URL=
FISCAL_API_TOKEN=

# ---------------------------------------------------------
# Mercado Pago
# Keep blank in staging unless this environment explicitly
# needs sandbox credentials.
# ---------------------------------------------------------
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_WEBHOOK_SECRET=

# ---------------------------------------------------------
# Stripe
# Keep blank in staging unless this environment explicitly
# needs sandbox credentials.
# ---------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------
# Transactional email
# MVP scope: manual communication plus templates
# ---------------------------------------------------------
EMAIL_PROVIDER=
EMAIL_FROM_NAME=PetOS
EMAIL_FROM_ADDRESS=no-reply@staging.petos.example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# ---------------------------------------------------------
# AI / LLMs
# MVP scope: message generation support
# ---------------------------------------------------------
OPENAI_API_KEY=
GEMINI_API_KEY=

# ---------------------------------------------------------
# Phase 3 AI foundation + Phase 4 tutor assistant
# The server expects literal strings `true` or `false`.
# Missing, blank or invalid values are treated conservatively
# and may block execution by fail-closed policy.
# Keep disabled unless this environment is intentionally
# operating the corresponding Phase 3 module.
# Base quotas are non-negative integers per module.
# ---------------------------------------------------------
AI_ENABLED=false
AI_IMAGE_ANALYSIS_ENABLED=false
AI_PREDICTIVE_INSIGHTS_ENABLED=false
AI_VIRTUAL_ASSISTANT_ENABLED=false
AI_IMAGE_ANALYSIS_BASE_QUOTA=
AI_PREDICTIVE_INSIGHTS_BASE_QUOTA=
AI_VIRTUAL_ASSISTANT_BASE_QUOTA=

# ---------------------------------------------------------
# Security and observability
# ---------------------------------------------------------
LOG_LEVEL=info
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ---------------------------------------------------------
# Technical fallback
# Unit-level configuration should override these values
# ---------------------------------------------------------
DEFAULT_CANCELLATION_WINDOW_HOURS=24
DEFAULT_RESCHEDULE_WINDOW_HOURS=24
DEFAULT_NO_SHOW_TOLERANCE_MINUTES=15
DEFAULT_PRE_CHECK_IN_WINDOW_HOURS=48
DEFAULT_DEPOSIT_EXPIRATION_MINUTES=60
DEFAULT_CLIENT_CREDIT_EXPIRATION_DAYS=180
DEFAULT_DOCUMENT_RETENTION_DAYS=180
DEFAULT_DOCUMENT_SIGNED_URL_TTL_SECONDS=900
DEFAULT_CRM_INACTIVE_DAYS=90
DEFAULT_CRM_REVIEW_DELAY_HOURS=24
DEFAULT_CRM_POST_SERVICE_DELAY_HOURS=6
DEFAULT_INVENTORY_ALLOW_NEGATIVE_STOCK=false
DEFAULT_PRODUCT_MIN_STOCK_QUANTITY=1
DEFAULT_POS_AUTO_FISCAL_DOCUMENT=false
DEFAULT_TEAM_SHIFT_MINUTES=480
DEFAULT_TIME_CLOCK_TOLERANCE_MINUTES=10
DEFAULT_PAYROLL_PERIOD_DAYS=30
DEFAULT_INTEGRATION_EVENT_RETENTION_DAYS=90
DEFAULT_CURRENCY=BRL
DEFAULT_TIMEZONE=America/Sao_Paulo
